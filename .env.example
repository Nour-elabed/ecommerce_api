PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dbname
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

# One-time SUPER_ADMIN setup (POST /api/setup/superadmin).
# Set this to a long random string before first deploy, use it on /setup,
# then REMOVE it from the environment immediately after success.
SETUP_SECRET=replace-with-a-long-random-string-you-choose
